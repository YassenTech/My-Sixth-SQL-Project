 /*adds a number beside each row 
 think of it as a row counter for each row*/
 SELECT Profession, 
 ROW_NUMBER() OVER(ORDER BY Annual_Income DESC) As RowCounter From Customers

 /*If Youre Wondering What "OVER" Does It Just Tells A Function To Look At A Set Of Rows Instead Of A Single
 What LAG Does : Fetches A Value From The Previous Row So You Can Compare It To The Current One.

 Heres An Example 
 Row 1: Current 15000 I	Previous : NULL 
 Row 2: Current 35000 I Previous : 15000
 Row 3: Current 86000 I Previous : 35000 

 And So On.*/
 SELECT Annual_Income,LAG(Annual_Income) OVER(Order BY CustomerID) As ComparesPreviousValuesToTheCurrentOne From Customers
